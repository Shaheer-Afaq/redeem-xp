{
	"schemaVersion": 1,
	"id": "redeemxp",
	"version": "${version}",
	"name": "Redeem XP",
	"description": "Redeem and store xp with a simple command!",
	"authors": [
		"Quite_Kid"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/Shaheer-Afaq/redeem-xp"
	},
	"license": "MIT",
	"icon": "assets/redeem-xp/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
          "redeemxp.RedeemXP"
		],
		"client": [
          "redeemxp.client.RedeemXPClient"
		]
	},
	"mixins": [
		"redeem-xp.mixins.json",
		{
			"config": "redeem-xp.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.1",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}